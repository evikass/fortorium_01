// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // Vercel Postgres
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================
// УПРАВЛЕНИЕ СТУДИЕЙ
// ============================================

// Директор студии - главный управляющий
model StudioDirector {
  id                String   @id @default(cuid())
  name              String   @default("Директор")
  status            String   @default("active") // active, thinking, hiring
  budget            Float    @default(1000.0) // условный бюджет
  reputation        Int      @default(50) // 0-100
  
  // Текущие приоритеты
  currentFocus      String?  // на чём сфокусирован
  hiringPriority    String?  // кого нужно нанять
  
  lastDecisionAt    DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  decisions         DirectorDecision[]
}

// Решение директора
model DirectorDecision {
  id          String   @id @default(cuid())
  directorId  String
  type        String   // hire_agent, fire_agent, start_project, set_priority
  description String
  reasoning   String?  // почему принято решение
  impact      String?  // JSON с влиянием на студию
  executed    Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  
  director    StudioDirector @relation(fields: [directorId], references: [id])
}

// ============================================
// HR ОТДЕЛ - НАЙМ АГЕНТОВ
// ============================================

// HR менеджер
model HRManager {
  id              String   @id @default(cuid())
  name            String   @default("HR Менеджер")
  status          String   @default("idle") // idle, searching, interviewing, hiring
  specialization  String?  // специализация поиска
  
  createdAt       DateTime @default(now())
  
  vacancies       Vacancy[]
  candidates      AgentCandidate[]
  hireRequests    HireRequest[]
}

// Вакансия
model Vacancy {
  id              String   @id @default(cuid())
  hrManagerId     String
  
  title           String   // "Сценарист комедий"
  role            String   // writer, artist, animator, etc.
  description     String   // описание требований
  
  // Требования к кандидату
  requiredSkills  String   // JSON массив ["comedy", "dialogue"]
  preferredStyle  String?  // "disney", "anime", etc.
  experienceLevel String   @default("any") // junior, middle, senior, any
  
  // Условия
  salary          Float?   // условная зарплата
  priority        Int      @default(5) // 1-10
  
  status          String   @default("open") // open, closed, filled
  createdAt       DateTime @default(now())
  closedAt        DateTime?
  
  hrManager       HRManager      @relation(fields: [hrManagerId], references: [id])
  candidates      AgentCandidate[]
  hireRequest     HireRequest?
}

// Кандидат на вакансию
model AgentCandidate {
  id              String   @id @default(cuid())
  vacancyId       String
  hrManagerId     String
  
  // Информация о кандидате
  name            String
  role            String
  description     String
  
  // Навыки и опыт
  skills          String   // JSON массив
  specializations String?  // JSON массив специализаций
  style           String?  // предпочитаемый стиль
  experience      String?  // описание опыта
  portfolioUrl    String?
  
  // Оценка
  rating          Int      @default(0) // 0-100
  interviewNotes  String?
  
  status          String   @default("pending") // pending, reviewing, accepted, rejected
  createdAt       DateTime @default(now())
  
  vacancy         Vacancy       @relation(fields: [vacancyId], references: [id])
  hrManager       HRManager     @relation(fields: [hrManagerId], references: [id])
}

// Запрос на найм
model HireRequest {
  id            String   @id @default(cuid())
  vacancyId     String   @unique
  hrManagerId   String
  
  // Кого нанимаем
  candidateName String
  candidateRole String
  candidateSkills String // JSON
  
  // Статус
  status        String   @default("pending") // pending, approved, rejected
  approvedBy    String?  // director id
  rejectionReason String?
  
  createdAt     DateTime @default(now())
  processedAt   DateTime?
  
  vacancy       Vacancy       @relation(fields: [vacancyId], references: [id])
  hrManager     HRManager     @relation(fields: [hrManagerId], references: [id])
}

// ============================================
// РЕЕСТР АГЕНТОВ (ТИПЫ)
// ============================================

// Тип агента - шаблон для найма
model AgentType {
  id            String   @id @default(cuid())
  name          String   // "Сценарист комедий", "Художник аниме"
  role          String   // writer, artist, animator, voice, editor, blender
  
  description   String
  baseSkills    String   // JSON массив базовых навыков
  specializations String // JSON массив специализаций
  
  // Параметры
  baseCost      Float    @default(10.0) // базовая стоимость найма
  rarity        String   @default("common") // common, rare, epic, legendary
  
  // Промпты для AI
  systemPrompt  String   // системный промпт для этого типа
  avatarEmoji   String   @default("🤖")
  
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())

  hiredAgents   HiredAgent[]
}

// ============================================
// НАНЯТЫЕ АГЕНТЫ
// ============================================

// Нанятый агент
model HiredAgent {
  id            String   @id @default(cuid())
  agentTypeId   String?
  
  // Идентичность
  name          String
  role          String
  description   String
  avatarEmoji   String   @default("🤖")
  
  // Навыки
  skills        String   // JSON массив навыков
  specializations String // JSON массив специализаций
  preferredStyle String?
  
  // Характеристики
  level         Int      @default(1)
  experience    Int      @default(0)
  quality       Int      @default(50) // качество работы 0-100
  speed         Int      @default(50) // скорость работы 0-100
  
  // Состояние
  status        String   @default("idle") // idle, working, tired, error
  mood          Int      @default(80) // настроение 0-100
  energy        Int      @default(100) // энергия 0-100
  
  // Работа
  currentTaskId String?
  tasksCompleted Int    @default(0)
  totalRating    Float  @default(0.0) // средний рейтинг выполненных задач
  
  // Экономика
  salary        Float    @default(10.0) // зарплата за проект
  hiredAt       DateTime @default(now())
  lastActiveAt  DateTime?
  
  agentType     AgentType?     @relation(fields: [agentTypeId], references: [id])
  tasks         HiredAgentTask[]
  performance   AgentPerformance[]
}

// Задача нанятого агента
model HiredAgentTask {
  id            String   @id @default(cuid())
  projectId     String
  agentId       String
  
  type          String
  title         String
  description   String?
  
  input         String?  // JSON
  output        String?  // JSON
  
  status        String   @default("pending") // pending, in_progress, completed, error
  error         String?
  priority      Int      @default(5)
  
  // Оценка выполнения
  qualityScore  Int?     // 0-100
  reviewNotes   String?
  
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  
  agent         HiredAgent @relation(fields: [agentId], references: [id])
}

// История производительности агента
model AgentPerformance {
  id            String   @id @default(cuid())
  agentId       String
  
  date          DateTime @default(now())
  tasksCompleted Int    @default(0)
  averageQuality Float  @default(0.0)
  avgCompletionTime Float? // секунды
  
  notes         String?
  
  agent         HiredAgent @relation(fields: [agentId], references: [id])
}

// ============================================
// ПРОЕКТЫ
// ============================================

// Анимационный проект
model AnimationProject {
  id            String   @id @default(cuid())
  title         String
  description   String
  style         String?  // Ghibli, Disney, Pixar, etc.
  duration      Int      @default(30) // в секундах
  status        String   @default("draft") // draft, in_progress, completed, error

  // Результаты
  finalVideoUrl String?
  thumbnailUrl  String?

  // Настройки Blender
  blenderScenePath String?
  useBlender       Boolean @default(false)

  // Команда проекта
  assignedAgents String? // JSON массив ID нанятых агентов

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scenes        Scene[]
  assets        Asset[]
  logs          ProjectLog[]
}

// Сцена мультфильма
model Scene {
  id            String   @id @default(cuid())
  projectId     String
  order         Int

  title         String
  description   String
  duration      Float    @default(5.0) // секунды

  // Результаты
  imageUrl      String?
  videoUrl      String?
  audioUrl      String?

  // Blender
  blenderFile   String?
  cameraPath    String?

  // Назначенный агент
  assignedAgentId String?

  createdAt     DateTime @default(now())

  project       AnimationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Ресурс (изображение, видео, аудио)
model Asset {
  id            String   @id @default(cuid())
  projectId     String
  type          String   // image, video, audio, model3d, script
  name          String
  description   String?
  url           String
  metadata      String?  // JSON метаданные
  createdById   String?  // ID агента создавшего

  createdAt     DateTime @default(now())

  project       AnimationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// Лог проекта
model ProjectLog {
  id            String   @id @default(cuid())
  projectId     String
  agentId       String?
  level         String   // info, warning, error, success
  message       String
  metadata      String?  // JSON

  createdAt     DateTime @default(now())

  project       AnimationProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// ТЕХНИЧЕСКИЕ МОДЕЛИ
// ============================================

// Подключение к Blender (домашний компьютер)
model BlenderConnection {
  id            String   @id @default(cuid())
  name          String
  host          String
  port          Int      @default(9876)
  apiKey        String?
  status        String   @default("disconnected") // connected, disconnected, error
  lastConnected DateTime?
  createdAt     DateTime @default(now())
}

// Шаблон персонажа для мультфильмов
model CharacterTemplate {
  id               String   @id @default(cuid())
  name             String
  description      String
  stylePrompt      String // промпт для генерации
  referenceImages  String? // JSON массив URL
  createdAt        DateTime @default(now())
}
